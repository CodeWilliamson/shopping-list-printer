# keep-bridge
KEEP_GOOGLE_CLIENT_ID=
KEEP_GOOGLE_CLIENT_SECRET=
KEEP_GOOGLE_REDIRECT_URI=http://localhost:8787/oauth2callback
KEEP_GOOGLE_REFRESH_TOKEN=
KEEP_TARGET_NOTE_ID=
KEEP_POLL_INTERVAL_SECONDS=30
KEEP_USE_MOCK=true

# openHAB bridge target from keep-bridge
OPENHAB_BASE_URL=http://openhab.local:8080
OPENHAB_PRINT_ITEM=ShoppingListPrintTrigger
OPENHAB_API_TOKEN=

# ESP32 printer endpoint (used by openHAB rule)
ESP32_BASE_URL=http://esp32-printer.local
ESP32_PRINT_PATH=/print
ESP32_API_TOKEN=

# Optional
PRINT_TITLE=Shopping List
